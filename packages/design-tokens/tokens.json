{
  "base": {
    "font": {
      "family": "-apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif",
      "size": {
        "xs": "11px",
        "sm": "13px",
        "base": "15px",
        "lg": "17px",
        "xl": "20px",
        "2xl": "24px"
      },
      "lineHeight": {
        "tight": 1.25,
        "base": 1.5,
        "relaxed": 1.75
      },
      "weight": {
        "normal": 400,
        "medium": 500,
        "bold": 600
      }
    },
    "spacing": {
      "xs": "4px",
      "sm": "8px",
      "md": "12px",
      "base": "16px",
      "lg": "24px",
      "xl": "32px",
      "2xl": "48px"
    },
    "radius": {
      "sm": "6px",
      "base": "8px",
      "lg": "12px",
      "xl": "20px",
      "full": "9999px"
    },
    "shadow": {
      "sm": "0 1px 4px rgba(0, 0, 0, 0.06)",
      "base": "0 2px 8px rgba(0, 0, 0, 0.08)",
      "lg": "0 4px 16px rgba(0, 0, 0, 0.12)"
    },
    "animation": {
      "duration": {
        "fast": "150ms",
        "base": "250ms",
        "slow": "400ms"
      },
      "easing": {
        "default": "cubic-bezier(0.4, 0, 0.2, 1)",
        "in": "cubic-bezier(0.4, 0, 1, 1)",
        "out": "cubic-bezier(0, 0, 0.2, 1)"
      }
    }
  },
  "themes": {
    "default": {
      "name": "默认主题",
      "description": "中性蓝灰色调，适用于工具类、通用型小程序",
      "colors": {
        "bg": "#f5f5f5",
        "bgSecondary": "#eeeeee",
        "card": "#ffffff",
        "text": "#1a1a1a",
        "textSecondary": "#666666",
        "textMuted": "#999999",
        "border": "#e0e0e0",
        "primary": "#2563eb",
        "primaryDark": "#1d4ed8",
        "primaryLight": "#eff6ff",
        "success": "#16a34a",
        "successLight": "#f0fdf4",
        "warning": "#f59e0b",
        "warningLight": "#fffbeb",
        "danger": "#dc2626",
        "dangerLight": "#fef2f2"
      },
      "wxConfig": {
        "navigationBarBackgroundColor": "#ffffff",
        "navigationBarTextStyle": "black",
        "backgroundColor": "#f5f5f5"
      }
    },
    "food-tracker": {
      "name": "食物记录主题",
      "description": "暖橙色调，适用于食物/美食相关应用",
      "colors": {
        "bg": "#faf7f2",
        "bgSecondary": "#f5efe6",
        "card": "#ffffff",
        "text": "#2d1810",
        "textSecondary": "#5a4234",
        "textMuted": "#8b7355",
        "border": "#e8ddd0",
        "primary": "#e85d26",
        "primaryDark": "#c44d1e",
        "primaryLight": "#fff0eb",
        "success": "#16a34a",
        "successLight": "#f0fdf4",
        "warning": "#f59e0b",
        "warningLight": "#fffbeb",
        "danger": "#dc2626",
        "dangerLight": "#fef2f2"
      },
      "wxConfig": {
        "navigationBarBackgroundColor": "#ffffff",
        "navigationBarTextStyle": "black",
        "backgroundColor": "#faf7f2"
      }
    }
  }
}
